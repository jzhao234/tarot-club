# Tarot Club configuration. Copy to .env and fill in.

# Enables the OpenAI-compatible proxy (POST /v1/chat/completions). The ONLY
# credential Tarot Club needs. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Listen address. Loopback by default; if you bind a non-loopback host you MUST
# set ARCANA_API_TOKEN.
# ARCANA_ADDR=127.0.0.1:8090

# Optional shared secret. When set, /route, /stats, and /v1 require it via
# `Authorization: Bearer <token>` or `X-Arcana-Token: <token>`.
# ARCANA_API_TOKEN=

# Where ratchet pins + usage stats persist (JSON file). Set "" for in-memory.
# ARCANA_STATE_FILE=data/arcana-state.json

# Routing knobs (the tier→model map, example phrases, MIN_CONFIDENCE,
# MIN_MARGIN) live in src/routes.ts — edit there, then `npm run eval`.
